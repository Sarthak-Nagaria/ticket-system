# Port the HTTP server listens on
PORT=8080

# Path to the SQLite database file (created automatically if it doesn't exist)
DATABASE_PATH=ticket_system.db

# Secret key used to sign and verify JWTs. CHANGE THIS in production.
JWT_SECRET=change-this-secret-in-production

# How many hours a JWT remains valid after login
JWT_EXPIRY_HOURS=24

# Gin mode: "release" or "debug"
GIN_MODE=release
